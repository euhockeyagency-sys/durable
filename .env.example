PORT=3000
SITE_URL=https://example.com
CONTACT_EMAIL=privacy@example.com
PRIVACY_POLICY_VERSION=2026-07-18
TRUST_PROXY=1

SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_replace_me

TURNSTILE_SITE_KEY=replace_me
TURNSTILE_SECRET_KEY=replace_me
TURNSTILE_EXPECTED_HOSTNAME=example.com

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Email notifications. RESEND_API_KEY alone is enough to switch them on:
# the recipient falls back to CONTACT_EMAIL and the sender to Resend's shared
# test address, which delivers to the address the Resend account was created
# with. Set RESEND_FROM to your own verified domain once its DNS is ready, and
# NOTIFICATION_EMAIL only if applications should go somewhere other than
# CONTACT_EMAIL.
RESEND_API_KEY=re_replace_me
# RESEND_FROM="EHA Website <applications@example.com>"
# NOTIFICATION_EMAIL=agent@example.com
